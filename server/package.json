{
  "name": "react-app-server",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "npm run build:dev && concurrently -k -n build,server --prefix \"[{name}]\" \"npm:dev:build\" \"npm:dev:serve\"",
    "build:dev": "webpack --mode development",
    "dev:build": "webpack --mode development --watch",
    "dev:serve": "nodemon --quiet --watch dist --ext cjs,json --exec node dist/server.cjs",
    "build": "webpack --mode production",
    "start": "node dist/server.cjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^20.19.39",
    "concurrently": "^9.2.1",
    "nodemon": "^3.1.14",
    "ts-loader": "^9.5.7",
    "typescript": "^6.0.3",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2"
  }
}
